# CMake build tree (downloaded JUCE, compiled objects, artefacts)
Builds/
build/

# Generated / compiled docs (regenerated by pandoc + Chrome from the .md source)
Docs/NeuralStage-Manual.html
Docs/NeuralStage-Manual.pdf
Docs/NeuralStage-Manual-new.pdf
Docs/NeuralStage-Manual.docx

# Old and current compiled installer archives
Installer/Neural*/
Installer/NeuralStage.v.*/
Installer/*.zip

# Pre-built release archives staged locally — published as GitHub Release assets,
# not committed to the repo.
Installer/WIN/
Installer/LINUX/
Installer/MAC/

# Claude local settings
.claude/

# Redundant plain-text copies (kept as Installer/NeuralStage-ReleaseNotes.txt)
CHANGELOG.txt
README.txt

# Staged installer binaries (populated by build.ps1)
Installer/Binaries/

# Compiled installer output
Installer/Output/

# Dev build-log scratch files
build-*.txt
build_*.log
build_*.txt
*.log

# Backup folders
Backups/
_Backups/

# Visual Studio / Rider local state
.vs/
*.user
*.suo
*.VC.db
*.VC.opendb

# JUCE if vendored separately
ThirdParty/JUCE/

# ASIO SDK — Steinberg license prohibits redistribution.
# Download from https://www.steinberg.net/asiosdk and place at ThirdParty/ASIOSDK/.
# CMakeLists.txt detects it automatically; without it the build falls back to WASAPI.
ThirdParty/ASIOSDK/

# IDE
.cache/
.vscode/ipch/
compile_commands.json
*.xcworkspace/
*.xcodeproj/

# macOS
.DS_Store
__MACOSX/

# Windows
Thumbs.db
desktop.ini
